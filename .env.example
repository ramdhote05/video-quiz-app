# Copy this file to ".env" and fill in your own values.

# --- Optional: Groq cloud API (free tier) ---
# Sign up free at https://console.groq.com to get a key, then paste it below
# to use a real LLM (Mixtral / Llama family) for higher-quality summaries and
# quizzes. Leave blank to run fully offline on the local fallback models.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# --- Whisper transcription settings ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Local offline summarization fallback (used if GROQ_API_KEY is blank) ---
LOCAL_SUMMARY_MODEL=sshleifer/distilbart-cnn-12-6

# --- App settings ---
NUM_QUIZ_QUESTIONS=5
MAX_UPLOAD_MB=500
SECRET_KEY=change-this-to-something-random
